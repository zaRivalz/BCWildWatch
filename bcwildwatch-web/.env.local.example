# Auth.js
AUTH_SECRET=                 # generate: npx auth secret
AUTH_MICROSOFT_ENTRA_ID_ID=309d9f76-7219-447d-9139-9350cdaf18e9   # app registration client id
AUTH_MICROSOFT_ENTRA_ID_SECRET=      # client secret value (create one in the app registration)
# Belgium Campus tenant (ea1a909b) — where backend resources + campus users live.
AUTH_MICROSOFT_ENTRA_ID_ISSUER=https://login.microsoftonline.com/ea1a909b-6600-4a25-82a5-0c6ed7d0513b/v2.0
# Dataverse service principal (same app reg)
AAD_CLIENT_ID=309d9f76-7219-447d-9139-9350cdaf18e9
AAD_CLIENT_SECRET=
AAD_TENANT_ID=ea1a909b-6600-4a25-82a5-0c6ed7d0513b
# Base origin OR full Web API URL — the app derives the origin either way.
DATAVERSE_URL=https://bcwildwatch.api.crm14.dynamics.com
# Microsoft Graph / SharePoint
SHAREPOINT_HOSTNAME=belgiumcampusacza.sharepoint.com
SHAREPOINT_SITE_PATH=/sites/BCWildWatchTeam2
SHAREPOINT_DRIVE_NAME=Documents      # Graph drive name of the "Shared Documents" library
SHAREPOINT_FOLDER=Media              # subfolder within the library for uploads
# App
ADMIN_EMAILS=you@belgiumcampus.ac.za
# Power BI live-sightings MAP publish-to-web URL (app.powerbi.com/view?r=...).
# NOTE: a /embed?dashboardId=... URL is a SECURED embed, not publish-to-web, and
# will NOT render in a public iframe — use the "Publish to web" share link.
POWERBI_MAP_URL=
# Power BI ADMIN DASHBOARD publish-to-web URL (app.powerbi.com/view?r=...).
# Same publish-to-web caveat as the map above. Shown only on the Admin page.
POWERBI_DASHBOARD_URL=
# Copilot Studio chatbot embed URL (custom-website channel). Empty = Safety page
# shows "Assistant not configured". CSP frame-src already allows the Copilot domain.
CHATBOT_URL=
